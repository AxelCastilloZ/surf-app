SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string — Supabase Dashboard → Project Settings → Database → Connection string → URI
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

PORT=3000
WEB_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Resend (email transaccional) ──
# API key: resend.com/api-keys → Create API Key
# MAIL_FROM requiere dominio verificado en Resend. Mientras no esté verificado, usar onboarding@resend.dev para pruebas.
RESEND_API_KEY=
MAIL_FROM=Surfers Lab CR <info@surferlabscr.com>
STAFF_NOTIFY_EMAIL=info@surferlabscr.com

# Google Places API (opcional — si no está definido, el endpoint /reviews devuelve [])
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Seed superadmin (solo para el script pnpm seed:superadmin) ──
# Completar antes de correr el seed por primera vez, luego se pueden borrar.
SEED_EMAIL=
SEED_PASSWORD=
SEED_FULL_NAME=
